# Telegram Bot (grammY)
TELEGRAM_BOT_TOKEN=

# Telegram MTProto (GramJS - personal account)
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
GRAMJS_SESSION=

# HydraDB
HYDRADB_API_KEY=
# Optional alias used in official docs/examples
HYDRA_DB_API_KEY=
HYDRA_TENANT_ID=tg-group-bot
HYDRA_WRITE_SCOPE=group
HYDRA_RECALL_SCOPE=group
GLOBAL_SUB_TENANT_ID=global-knowledge
HYDRA_MAX_RECALL_RESULTS=25
HYDRA_RECALL_BREADTH_RESULTS=40
# Use only if tenant metadata schema contains the provided keys.
HYDRA_USE_METADATA_FILTERS=0
HYDRA_VERIFY_PROCESSING_ON_SEED=1
HYDRA_VERIFY_POLL_INTERVAL_MS=3000
HYDRA_VERIFY_MAX_WAIT_MS=300000

# Bot runtime
BOT_DEBUG=0
AGENT_PIPELINE_ENABLED=1

# LLM Provider: anthropic | openai | gemini
LLM_PROVIDER=anthropic

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Optional separate model for planner/reranker/function-calling
AGENT_GEMINI_MODEL=gemini-2.5-flash
GEMINI_MAX_RETRIES=2
GEMINI_RETRY_BASE_MS=1500

# Local
SQLITE_DB_PATH=./data/bot.db
PORT=3000

# Seeder controls (optional)
SEED_MESSAGE_LIMIT=1
SEED_TARGET_GROUP_ID=
SEED_TARGET_GROUP_NAME=
